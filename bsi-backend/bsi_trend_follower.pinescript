//@version=5
strategy("BSI Trend Follower MVP", overlay=true, initial_capital=10000, pyramiding=0)

// =========================
// Parâmetros
// =========================
ema_period = input.int(200, "EMA Trend Filter")
rsi_period = input.int(14, "RSI Period")
atr_period = input.int(14, "ATR Period")

// =========================
// Indicadores
// =========================
ema200 = ta.ema(close, ema_period)
rsi = ta.rsi(close, rsi_period)
atr = ta.atr(atr_period)
ema200_dist = ((close - ema200) / ema200) * 100.0

// =========================
// Condições de Entrada
// =========================
long_condition = close > ema200 and ta.crossover(rsi, 50)
short_condition = close < ema200 and ta.crossunder(rsi, 50)

// NOTA: Próxima melhoria - implementar strategy.exit com IDs dinâmicos
// para permitir que o sistema capture o outcome (vitoria/derrota) automaticamente.
if long_condition
    strategy.entry("Long", strategy.long)
if short_condition
    strategy.entry("Short", strategy.short)

// =========================
// Construção do Payload JSON
// =========================
dir = long_condition ? "LONG" : "SHORT"
ext_id = syminfo.ticker + "_" + timeframe.period + "_" + dir + "_" + str.tostring(time)

json_msg = "{" +
    "\"payload_version\":\"1.0\"," +
    "\"external_signal_id\":\"" + ext_id + "\"," +
    "\"asset\":\"" + syminfo.ticker + "\"," +
    "\"market\":\"CRYPTO\"," +
    "\"timeframe\":\"" + timeframe.period + "\"," +
    "\"signal_type\":\"ENTRY\"," +
    "\"signal_direction\":\"" + dir + "\"," +
    "\"trigger_price\":" + str.tostring(close) + "," +
    "\"signal_timestamp\":\"" + str.format_time(time, "yyyy-MM-dd'T'HH:mm:ss'Z'") + "\"," +
    "\"strategy_name\":\"BSI_Trend_Follower\"," +
    "\"strategy_version\":\"1.0.0\"," +
    "\"indicator_snapshot\":{" +
        "\"rsi\":" + str.tostring(rsi) + "," +
        "\"atr\":" + str.tostring(atr) + "," +
        "\"ema200_distance_pct\":" + str.tostring(ema200_dist) +
    "}," +
    "\"candle_context\":{" +
        "\"open\":" + str.tostring(open) + "," +
        "\"high\":" + str.tostring(high) + "," +
        "\"low\":" + str.tostring(low) + "," +
        "\"close\":" + str.tostring(close) + "," +
        "\"volume\":" + str.tostring(volume) +
    "}" +
"}"

// =========================
// Alerta Webhook
// =========================
if (long_condition or short_condition) and barstate.isconfirmed
    alert(json_msg, alert.freq_once_per_bar_close)
