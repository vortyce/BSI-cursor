# Configuração de Banco de Dados
# Para Demo: sqlite:///./bsi_demo.db
# Para Produção: postgresql://user:password@localhost:5432/bsi_db
DATABASE_URL=sqlite:///./bsi_demo.db

# Configurações do App
APP_NAME="BTC Signal Intelligence"
DEBUG=True

# Integrações (LLM)
# Obter chave em platform.openai.com
OPENAI_API_KEY=your-key-here

# TradingView Webhook Security (Opcional)
WEBHOOK_SECRET=your-secret-here
